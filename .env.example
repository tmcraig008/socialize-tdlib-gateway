# Copy to .env for local dev

# Must match Socialize backend Railway vars (WEB_API_KEY / TDLIB_GATEWAY_API_KEY)
WEB_API_KEY=change-me-long-random-secret

# Socialize Node backend public URL (MUST include http:// or https://, no trailing slash)
# Used to POST incoming TDLib updates to /api/telegram/tdlib/webhook
SOCIALIZE_BACKEND_URL=http://localhost:3002

# Public URL of this gateway service (used to generate inbound media links for Socialize).
# On Railway you can usually leave this blank and rely on RAILWAY_PUBLIC_DOMAIN.
# GATEWAY_PUBLIC_URL=https://your-gateway.up.railway.app

# Telegram app credentials (https://my.telegram.org)
API_ID=
API_HASH=

# Where TDLib stores per-workspace session files (persistent volume on Railway)
TDLIB_DATA_ROOT=./tdlib_data

# Must stay constant for a given data folder (matches TG no Bot / pytdbot setup)
# DATABASE_ENCRYPTION_KEY=

# TDLib library log verbosity (0-4)
# TD_VERBOSITY=1

# mock = HTTP API works; sends are simulated (good for wiring Railway + env vars)
# live  = use real TDLib via pytdbot (requires native TDLib + correct paths)
TDLIB_MODE=mock
